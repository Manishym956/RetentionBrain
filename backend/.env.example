# RetentionBrain backend environment example
# Copy to backend/.env and fill values for your environment.

# Core Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.yourdomain.com
TIME_ZONE=UTC
LOG_LEVEL=INFO

# Frontend / CORS
FRONTEND_URL=https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com

# Access mode
# Keep this true while deploying without auth gates on core product flows.
OPEN_ACCESS_MODE=True
ANONYMOUS_USER_PREFIX=guest

# Database
# Production Postgres example:
DATABASE_URL=postgresql://neondb_owner:npg_xUtjeJTaF4H2@ep-jolly-term-ao6r3te3-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_SSL_MODE=require
DB_CONN_MAX_AGE=60

# Local SQLite fallback
# SQLITE_PATH=C:/path/to/backend/db.sqlite3

# Model
MODEL_PATH=
MODEL_VERSION=v1

# JWT
JWT_SIGNING_KEY=replace-with-a-separate-jwt-signing-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
UPLOAD_THROTTLE_RATE=20/hour

# Static / media
MEDIA_URL=/media/
MEDIA_ROOT=

# HTTPS / proxy
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Google Cloud Storage
# Install django-storages and google-cloud-storage before enabling.
USE_GCP_STORAGE=False
GCP_BUCKET_NAME=retentionbrain-prod
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_PATH=
GCP_CREDENTIALS_JSON=
GCP_SIGNED_URLS=False
GCP_SIGNED_URL_EXPIRATION=900

# SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=alerts@yourdomain.com
EMAIL_HOST_PASSWORD=app-password-or-smtp-secret
DEFAULT_FROM_EMAIL=RetentionBrain <alerts@yourdomain.com>
PASSWORD_RESET_FRONTEND_PATH=/auth/reset-password

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/api/auth/google/callback/
GOOGLE_OAUTH_SCOPES=openid,email,profile
